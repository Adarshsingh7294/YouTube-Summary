# OpenAI API key (required)
OPENAI_API_KEY=your_api_key_here

# Base URL for the OpenAI-compatible endpoint (defaults to OpenAI)
# Use this to point at any OpenAI-compatible provider:
#   - https://api.openai.com/v1 (OpenAI)
#   - https://openrouter.ai/api/v1 (OpenRouter)
#   - https://api.groq.com/openai/v1 (Groq)
#   - http://localhost:11434/v1 (Ollama)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name to use for the completion (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Supadata API key (recommended for production / Vercel)
# YouTube blocks direct transcript scraping from datacenter IPs, so we
# delegate the fetch to Supadata.ai which runs the request on residential
# IPs. Free tier: 100 transcripts / month. Sign up at https://supadata.ai
# and paste the key below. If left empty, the app falls back to local
# scraping (which works on localhost but rarely on Vercel).
SUPADATA_API_KEY=sd_7b011688df8e0622af389fe48a5fc6e8
